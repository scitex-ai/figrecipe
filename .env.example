# figrecipe environment variables
#
# Copy to .env (or source from your shell profile) and adjust values.
# All variables are optional; defaults shown after `=`.

# Path to a figrecipe YAML config file. Overrides `./config.yaml`
# and `~/.scitex/figrecipe/config.yaml` lookup order.
# FIGRECIPE_CONFIG=./config.yaml

# Base directory for SciTeX cache, state, and per-package config.
# figrecipe reads `~/.scitex/figrecipe/config.yaml` from this location.
SCITEX_DIR=~/.scitex
